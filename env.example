# Database (required — Prisma reads process.env.DATABASE_URL)
# Local:
# DATABASE_URL="postgresql://user:password@localhost:5432/ksa_entry_os?schema=public"
# Railway: attach Postgres and set DATABASE_URL on the *web* service.
# After first deploy: npx prisma db push && npx tsx prisma/seed.ts
DATABASE_URL="postgresql://user:password@localhost:5432/ksa_entry_os?schema=public"

# Auth (generate with: openssl rand -base64 32) — min 32 chars; required in production
AUTH_SECRET="change-me-to-a-secure-random-string-min-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Redis (required in production for distributed rate limiting)
# Railway: add Redis plugin and set REDIS_URL on the web service
REDIS_URL=""
# Only set in production if you explicitly accept single-instance memory limits:
# ALLOW_MEMORY_RATE_LIMIT="true"

# Demo payments — NEVER set true in production (startup will fail if true)
# Local only: ALLOW_DEMO_PAYMENTS="true"
ALLOW_DEMO_PAYMENTS="false"

# Optional: real payment provider (when both set, payments are considered configured)
PAYMENT_PROVIDER_KEY=""
PAYMENT_WEBHOOK_SECRET=""

# Admin seed credentials (change after first login; insecure defaults refused in production seed)
SEED_ADMIN_EMAIL="admin@ksaentryos.com"
SEED_ADMIN_PASSWORD="ChangeMe123!Secure"
